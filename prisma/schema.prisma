generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id       String @id @default(uuid())
  rolename String @unique
  users    User[]
}

model Nationality {
  id       String    @id @default(uuid())
  label    String
  students Student[]
}

model FrenchLevel {
  id              String    @id @default(uuid())
  description     String?
  code            String?
  studentsInitial Student[] @relation("InitialLevel")
  studentsCurrent Student[] @relation("CurrentLevel")
  studentsDeparture Student[] @relation("DepartureLevel")
}

model Gender {
  id       String    @id @default(uuid())
  label    String
  students Student[]
}

model Address {
  id         String           @id @default(uuid())
  street     String
  complement String?
  city       String
  country    String           @default("France")
  zipcode    Int
  students   StudentAddress[]
}

model ExitReason {
  id       String    @id @default(uuid())
  reason   String
  students Student[]
}

model Orientation {
  id          String    @id @default(uuid())
  type        String
  description String?
  students    Student[]
}

model Period {
  id            String        @id @default(uuid())
  label         String
  startedAt     DateTime
  endedAt       DateTime
  actual_period Boolean       @default(false)
  groups        GroupPeriod[]
}

model Session {
  id         String   @id @default(uuid())
  startedAt  DateTime
  finishedAt DateTime
  label      String?
  groups     Group[]
}

model Status {
  id       String    @id @default(uuid())
  label    String
  students Student[]
}

model Financing {
  id       String    @id @default(uuid())
  type     String
  students Student[]
}

model Disability {
  id          String              @id @default(uuid())
  label       String
  description String?
  students    StudentDisability[]
}

model User {
  id        String       @id @default(uuid())
  firstname String
  lastname  String
  email     String       @unique
  password  String
  role_id   String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  birthdate DateTime?
  isActive  Boolean      @default(true)
  tasks     Task[]
  role      Role         @relation(fields: [role_id], references: [id])
  courses   UserCourse[]
  learner_history_changes LearnerHistory[]
}

model Student {
  id                 String              @id @default(uuid())
  firstname          String
  lastname           String
  birthdate          DateTime
  email              String?
  phone              String?
  commentaire        String?
  date_entree_france String?
  gender_id          String
  nationality_id     String
  orientation_id     String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  initial_level_id   String              // Niveau initial (à l'arrivée)
  current_level_id   String?             // Niveau actuel (évolutif pendant formation)
  departure_level_id String?             // Niveau de sortie (quand il quitte après formation)
  date_test_initial  String?
  exit_reason_id     String?
  financing_id       String
  placeOfBirth       String?
  status_id          String
  date_cir           DateTime?
  date_titre_sejour  DateTime?
  absences           Absence[]
  continuation       Continuation?
  exams              Exam[]
  history            LearnerHistory[]
  initialLevel       FrenchLevel         @relation("InitialLevel", fields: [initial_level_id], references: [id])
  currentLevel       FrenchLevel?        @relation("CurrentLevel", fields: [current_level_id], references: [id])
  departureLevel     FrenchLevel?        @relation("DepartureLevel", fields: [departure_level_id], references: [id])
  exitReason         ExitReason?         @relation(fields: [exit_reason_id], references: [id])
  financing          Financing           @relation(fields: [financing_id], references: [id])
  gender             Gender              @relation(fields: [gender_id], references: [id])
  nationality        Nationality         @relation(fields: [nationality_id], references: [id])
  orientation        Orientation?        @relation(fields: [orientation_id], references: [id])
  status             Status              @relation(fields: [status_id], references: [id])
  addresses          StudentAddress[]
  disabilities       StudentDisability[]
  groups             StudentGroup[]
}

model StudentDisability {
  id            String     @id @default(uuid())
  student_id    String
  disability_id String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  disability    Disability @relation(fields: [disability_id], references: [id])
  student       Student    @relation(fields: [student_id], references: [id])
  
  @@unique([student_id, disability_id])
}

model Task {
  id                   String    @id @default(uuid())
  title                String
  description          String?
  status               String    @default("pending") // pending, in_progress, completed (calculé)
  completionPercentage Decimal   @default(0) @db.Decimal(15, 2)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  dueAt                DateTime?
  
  // Relation avec l'utilisateur
  user                 User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id              String
  
  // Relation avec les sous-tâches
  subtasks             Subtask[]
}

model Subtask {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("pending") // pending, completed SEULEMENT
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relation avec la tâche parente
  task        Task     @relation(fields: [task_id], references: [id], onDelete: Cascade)
  task_id     String
}

model Group {
  id         String         @id @default(uuid())
  label      String
  session_id String
  courses    Course[]
  session    Session        @relation(fields: [session_id], references: [id])
  periods    GroupPeriod[]
  students   StudentGroup[]
}

model Course {
  day        DateTime?
  end_hour   DateTime?
  group_id   String
  intitule   String?
  start_hour DateTime?
  course_id  String       @id @default(uuid())
  absences   Absence[]
  group      Group        @relation(fields: [group_id], references: [id])
  users      UserCourse[]
  
  @@index([group_id])
}

model Exam {
  id         String   @id @default(uuid())
  label      String
  note       String?
  student_id String
  taked_at   DateTime
  student    Student  @relation(fields: [student_id], references: [id])
}

model Continuation {
  id          String  @id @default(uuid())
  temporality String?
  commentary  String?
  student_id  String  @unique
  student     Student @relation(fields: [student_id], references: [id])
}

model Absence {
  id         String  @id @default(uuid())
  reason     String?
  student_id String
  course_id  String
  course     Course  @relation(fields: [course_id], references: [course_id])
  student    Student @relation(fields: [student_id], references: [id])
  
  @@unique([student_id, course_id])
}

model StudentAddress {
  id         String  @id @default(uuid())
  student_id String
  address_id String
  address    Address @relation(fields: [address_id], references: [id])
  student    Student @relation(fields: [student_id], references: [id])
  
  @@unique([student_id, address_id])
}

model StudentGroup {
  id         String  @id @default(uuid())
  student_id String
  group_id   String
  group      Group   @relation(fields: [group_id], references: [id])
  student    Student @relation(fields: [student_id], references: [id])
  
  @@unique([student_id, group_id])
}

model UserCourse {
  id        String @id @default(uuid())
  user_id   String
  course_id String
  course    Course @relation(fields: [course_id], references: [course_id])
  user      User   @relation(fields: [user_id], references: [id])
  
  @@unique([user_id, course_id])
}

model GroupPeriod {
  id        String @id @default(uuid())
  group_id  String
  period_id String
  group     Group  @relation(fields: [group_id], references: [id])
  period    Period @relation(fields: [period_id], references: [id])
  
  @@unique([group_id, period_id])
}

model LearnerHistory {
  id          String   @id @default(uuid())
  
  // ID de l'étudiant concerné (toujours présent)
  student_id  String
  
  // Type d'entité modifiée (student, exam, absence, group, continuation, etc.)
  entity_type String   // 'student', 'exam', 'absence', 'group_assignment', 'continuation', 'address', 'disability'
  
  // ID de l'entité modifiée (null pour les modifications directes de l'étudiant)
  entity_id   String?
  
  // Type d'action effectuée
  action_type String   // 'created', 'updated', 'deleted', 'assigned', 'unassigned'
  
  // Type de changement spécifique
  change_type String   // 'level_change', 'status_change', 'exam_taken', 'group_change', 'personal_info_update', etc.
  
  // Date du changement
  change_date DateTime @default(now())
  
  // Données avant changement (JSON)
  previous_data Json?
  
  // Nouvelles données (JSON)
  new_data     Json?
  
  // Description du changement
  description  String?
  
  // ID de l'utilisateur qui a effectué le changement
  changed_by_user_id String?
  
  // Relations
  student     Student @relation(fields: [student_id], references: [id], onDelete: Cascade)
  changed_by  User?   @relation(fields: [changed_by_user_id], references: [id])
  
  @@index([student_id, change_date])
  @@index([entity_type, action_type])
  @@index([change_type])
  @@index([entity_id])
}

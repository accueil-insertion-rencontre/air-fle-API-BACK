# Configuration de la base de données
DATABASE_URL=postgresql://user:password@postgres-prod:5432/air_fle_prod?schema=public

# Configuration Redis
REDIS_URL=redis://redis-prod:6379

# Configuration JWT
JWT_SECRET=votre_clé_secrète_très_sécurisée_pour_production
JWT_EXPIRES_IN=1d

# Configuration du port de l'application
PORT=3000

# Mode de l'environnement
NODE_ENV=production
